{
  "name": "nairavault",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite --config vite.config.ts",
    "server": "nodemon --exec ts-node --project tsconfig.json --ext ts server/index.ts",
    "build": "vite build --config vite.config.ts && tsc --project tsconfig.json",
    "build:client": "vite build --config vite.config.ts",
    "build:server": "tsc --project tsconfig.json",
    "start": "node server-dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "NairaVault - Telegram Mini App FinTech Platform",
  "dependencies": {
    "@tanstack/react-query": "^5.101.1",
    "@vitejs/plugin-react": "^6.0.3",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.3",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "uuid": "^14.0.1",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.5.2",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.86.0"
  }
}
